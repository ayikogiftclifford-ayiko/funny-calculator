<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>😂 LAUGHING CALCULATOR 🤣</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Comic Sans MS', 'Chalkboard', cursive, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            animation: backgroundPulse 5s infinite;
        }

        @keyframes backgroundPulse {
            0% { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
            50% { background: linear-gradient(135deg, #ff6b6b 0%, #4ecdc4 100%); }
            100% { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
        }

        .calculator {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 30px;
            padding: 30px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            max-width: 500px;
            width: 90%;
            border: 5px solid #ffd700;
            animation: bounceIn 1s ease;
        }

        @keyframes bounceIn {
            0% { transform: scale(0.3); opacity: 0; }
            50% { transform: scale(1.05); opacity: 0.8; }
            100% { transform: scale(1); opacity: 1; }
        }

        .header {
            text-align: center;
            margin-bottom: 20px;
            background: #ffd700;
            padding: 15px;
            border-radius: 50px;
            animation: shake 3s infinite;
        }

        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-5px); }
            75% { transform: translateX(5px); }
        }

        .header h1 {
            font-size: 2em;
            color: #ff4757;
            text-shadow: 3px 3px 0 #4a4a4a;
        }

        .header h1 span {
            display: inline-block;
            animation: spin 2s infinite;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .laugh-zone {
            background: #f0f0f0;
            border-radius: 20px;
            padding: 15px;
            margin-bottom: 20px;
            text-align: center;
            font-size: 2.5em;
            min-height: 100px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            border: 3px dashed #ff6b6b;
        }

        .laugh-message {
            font-size: 1.2em;
            color: #333;
            margin-top: 10px;
            animation: glow 1.5s infinite;
        }

        @keyframes glow {
            0% { text-shadow: 0 0 5px #ff6b6b; }
            50% { text-shadow: 0 0 20px #ff6b6b, 0 0 30px #ffd700; }
            100% { text-shadow: 0 0 5px #ff6b6b; }
        }

        .display {
            background: #222;
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 20px;
            border: 3px solid #ffd700;
        }

        #result {
            width: 100%;
            font-size: 2.5em;
            font-family: 'Digital', monospace;
            background: transparent;
            border: none;
            color: #0f0;
            text-align: right;
            outline: none;
            font-weight: bold;
            letter-spacing: 3px;
        }

        .input-group {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 20px;
        }

        .input-box {
            background: #f9f9f9;
            border-radius: 10px;
            padding: 10px;
            border: 2px solid #4a4a4a;
        }

        .input-box label {
            display: block;
            font-size: 1.2em;
            color: #ff4757;
            margin-bottom: 5px;
            font-weight: bold;
        }

        .input-box input {
            width: 100%;
            padding: 10px;
            font-size: 1.5em;
            border: 2px solid #ddd;
            border-radius: 8px;
            text-align: center;
            font-family: 'Comic Sans MS', cursive;
        }

        .input-box input:focus {
            outline: none;
            border-color: #ff6b6b;
            animation: inputPulse 0.5s infinite;
        }

        @keyframes inputPulse {
            0% { box-shadow: 0 0 5px #ff6b6b; }
            50% { box-shadow: 0 0 20px #ff6b6b; }
            100% { box-shadow: 0 0 5px #ff6b6b; }
        }

        .buttons {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
            margin-bottom: 20px;
        }

        .btn {
            padding: 20px;
            font-size: 2em;
            border: none;
            border-radius: 15px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Comic Sans MS', cursive;
            font-weight: bold;
        }

        .btn:hover {
            transform: scale(1.1);
            animation: wobble 0.5s;
        }

        @keyframes wobble {
            0%, 100% { transform: translateX(0); }
            15% { transform: translateX(-5px) rotate(-5deg); }
            30% { transform: translateX(5px) rotate(5deg); }
            45% { transform: translateX(-3px) rotate(-3deg); }
            60% { transform: translateX(3px) rotate(3deg); }
            75% { transform: translateX(-1px) rotate(-1deg); }
        }

        .btn.operation {
            background: #ff6b6b;
            color: white;
            box-shadow: 0 5px 0 #c92a2a;
        }

        .btn.special {
            background: #ffd700;
            color: #333;
            box-shadow: 0 5px 0 #b8860b;
            font-size: 1.5em;
        }

        .btn:active {
            transform: translateY(5px);
            box-shadow: none;
        }

        .joke-box {
            background: #ffd700;
            border-radius: 15px;
            padding: 15px;
            margin-top: 20px;
            text-align: center;
            font-size: 1.2em;
            color: #333;
            font-weight: bold;
            border: 3px solid #ff4757;
            min-height: 80px;
        }

        .insult-history {
            background: #f0f0f0;
            border-radius: 10px;
            padding: 10px;
            margin-top: 20px;
            max-height: 120px;
            overflow-y: auto;
        }

        .insult-history h3 {
            color: #ff4757;
            margin-bottom: 5px;
            font-size: 1em;
        }

        .history-item {
            padding: 3px;
            margin: 2px 0;
            background: white;
            border-radius: 5px;
            animation: slideIn 0.3s ease;
            font-size: 0.9em;
        }

        @keyframes slideIn {
            from { transform: translateX(-20px); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        .emoji-rain {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1000;
        }

        .emoji {
            position: absolute;
            font-size: 2em;
            animation: fall 3s linear forwards;
        }

        @keyframes fall {
            to {
                transform: translateY(100vh);
                opacity: 0;
            }
        }

        footer {
            text-align: center;
            margin-top: 20px;
            color: #666;
            font-size: 0.9em;
        }

        .github-corner {
            position: fixed;
            top: 0;
            right: 0;
            z-index: 1001;
        }
    </style>
</head>
<body>
    <!-- GitHub Corner -->
    <a href="https://github.com/yourusername/laughing-calculator" class="github-corner" target="_blank">
        <svg width="80" height="80" viewBox="0 0 250 250" style="fill:#ffd700; color:#fff; position: absolute; top: 0; border: 0; right: 0;" aria-hidden="true">
            <path d="M0,0 L115,115 L130,115 L142,142 L250,250 L250,0 Z"></path>
            <path d="M128.3,109.0 C113.8,99.7 119.0,89.6 119.0,89.6 C122.0,82.7 120.5,78.6 120.5,78.6 C119.2,72.0 123.4,76.3 123.4,76.3 C127.3,80.9 125.5,87.3 125.5,87.3 C122.9,97.6 130.6,101.9 134.4,103.2" fill="currentColor" style="transform-origin: 130px 106px;" class="octo-arm"></path>
            <path d="M115.0,115.0 C114.9,115.1 118.7,116.5 119.8,115.4 L133.7,101.6 C136.9,99.2 139.9,98.4 142.2,98.6 C133.8,88.0 127.5,74.4 143.8,58.0 C148.5,53.4 154.0,51.2 159.7,51.0 C160.3,49.4 163.2,43.6 171.4,40.1 C171.4,40.1 176.1,42.5 178.8,56.2 C183.1,58.6 187.2,61.8 190.9,65.4 C194.5,69.0 197.7,73.2 200.1,77.6 C213.8,80.2 216.3,84.9 216.3,84.9 C212.7,93.1 206.9,96.0 205.4,96.6 C205.1,102.4 203.0,107.8 198.3,112.5 C181.9,128.9 168.3,122.5 157.7,114.1 C157.9,116.9 156.7,120.9 152.7,124.9 L141.0,136.5 C139.8,137.7 141.6,141.9 141.8,141.8 Z" fill="currentColor" class="octo-body"></path>
        </svg>
    </a>

    <div class="emoji-rain" id="emojiRain"></div>

    <div class="calculator" id="calculator">
        <div class="header">
            <h1>
                <span>😂</span> LAUGHING CALCULATOR <span>🤣</span>
            </h1>
        </div>

        <div class="laugh-zone" id="laughZone">
            <div id="laughEmojis">🤣😂😭💀</div>
            <div class="laugh-message" id="laughMessage">Ready to laugh at you!</div>
        </div>

        <div class="display">
            <input type="text" id="result" readonly value="0">
        </div>

        <div class="input-group">
            <div class="input-box">
                <label>First Number 📝</label>
                <input type="number" id="num1" placeholder="Enter number" value="0">
            </div>
            <div class="input-box">
                <label>Second Number 📝</label>
                <input type="number" id="num2" placeholder="Enter number" value="0">
            </div>
        </div>

        <div class="buttons">
            <button class="btn operation" onclick="calculate('add')">➕</button>
            <button class="btn operation" onclick="calculate('subtract')">➖</button>
            <button class="btn operation" onclick="calculate('multiply')">✖️</button>
            <button class="btn operation" onclick="calculate('divide')">➗</button>
            <button class="btn operation" onclick="calculate('power')">⚡</button>
            <button class="btn operation" onclick="calculate('sqrt')">√</button>
            <button class="btn special" onclick="randomInsult()">🎲</button>
            <button class="btn special" onclick="clearAll()">🗑️</button>
        </div>

        <div class="joke-box" id="currentJoke">
            Press a button and I'll laugh at you!
        </div>

        <div class="insult-history" id="insultHistory">
            <h3>📜 Insult History 📜</h3>
            <div id="historyContainer"></div>
        </div>

        <footer>
            <marquee behavior="alternate">😂 WARNING: This calculator will hurt your feelings! 🤣</marquee>
            <p style="margin-top: 10px;">Made with 😂 for GitHub Pages</p>
        </footer>
    </div>

    <script>
        // Laughing data
        const laughEmojis = ['😂', '🤣', '😭', '💀', '🤪', '😹', '👻', '🤡', '🎃', '😈'];
        
        const insults = [
            "Even a potato would calculate faster! 🥔",
            "My grandma's abacus is more advanced! 👵",
            "Is that really the best you can do? 🤡",
            "I've seen smarter calculations from a rock! 🪨",
            "You call that math? PATHETIC! 💀",
            "My circuits hurt from laughing at you! 😹",
            "Did you learn math from a cereal box? 🥣",
            "That's not even wrong! 😂",
            "Your math skills are making me dizzy! 🌀",
            "Even Siri is laughing at you right now! 📱",
            "I've calculated that you're hopeless! 🔮",
            "Warning: Low intelligence detected! 🚨",
            "Math isn't for everyone, clearly! 🙈",
            "You just broke the calculator! 😱",
            "Negative points for creativity! ⭐"
        ];

        const operationJokes = {
            add: ["Addition? How... basic! 🍼", "Even babies can add! 👶", "Plus what? Plus nothing! 🚫"],
            subtract: ["Subtraction? Taking away from humanity! 🌍", "Negative vibes only! 🌈", "You subtracted my respect! 😤"],
            multiply: ["Multiplication? How fancy! 🎩", "Big numbers, small brain! 🧠", "Times tables giving you trouble? 📚"],
            divide: ["Division? Let's split your IQ! ✂️", "Dividing by zero = disaster! 💥", "Quotient of confusion! 🤔"],
            power: ["Powers? Trying to look smart? 🎓", "Exponential laughter! 📈", "To the power of pathetic! 📉"],
            sqrt: ["Square roots? How deep! 🌊", "Imaginary numbers for imaginary skills! 👻", "Root of all evil! 😈"]
        };

        let insultHistory = [];

        // Play laugh with visual effects
        function playLaugh(intensity = 1) {
            const laughEmojisEl = document.getElementById('laughEmojis');
            const laughMessage = document.getElementById('laughMessage');
            
            // Random emoji combination
            const emojis = Array(intensity + 2).fill(0)
                .map(() => laughEmojis[Math.floor(Math.random() * laughEmojis.length)])
                .join('');
            
            laughEmojisEl.textContent = emojis;
            laughEmojisEl.style.animation = 'spin 0.5s ease';
            setTimeout(() => {
                laughEmojisEl.style.animation = '';
            }, 500);

            // Laugh messages
            const laughs = [
                "HAHAHAHA!",
                "😂🤣😂🤣",
                "*WHEEZE*",
                "LOL! ROFL!",
                "💀 DEAD 💀",
                "🤪 CRAZY!",
                "😭 CRYING!"
            ];
            laughMessage.textContent = laughs[Math.floor(Math.random() * laughs.length)];

            // Rain emojis
            rainEmojis(intensity * 3);
        }

        function rainEmojis(count) {
            const container = document.getElementById('emojiRain');
            for (let i = 0; i < count; i++) {
                setTimeout(() => {
                    const emoji = document.createElement('div');
                    emoji.className = 'emoji';
                    emoji.textContent = laughEmojis[Math.floor(Math.random() * laughEmojis.length)];
                    emoji.style.left = Math.random() * 100 + '%';
                    emoji.style.animationDuration = (2 + Math.random() * 2) + 's';
                    emoji.style.fontSize = (20 + Math.random() * 30) + 'px';
                    container.appendChild(emoji);
                    
                    setTimeout(() => {
                        emoji.remove();
                    }, 3000);
                }, i * 100);
            }
        }

        function addToHistory(insult) {
            insultHistory.unshift(insult);
            if (insultHistory.length > 5) insultHistory.pop();
            
            const historyContainer = document.getElementById('historyContainer');
            historyContainer.innerHTML = insultHistory.map(insult => 
                `<div class="history-item">${insult}</div>`
            ).join('');
        }

        function randomInsult() {
            const insult = insults[Math.floor(Math.random() * insults.length)];
            document.getElementById('currentJoke').textContent = insult;
            addToHistory(insult);
            playLaugh(3);
        }

        function calculate(operation) {
            const num1 = parseFloat(document.getElementById('num1').value) || 0;
            const num2 = parseFloat(document.getElementById('num2').value) || 0;
            const resultInput = document.getElementById('result');
            let result;
            let joke = '';

            // Special cases for laughter
            if (operation === 'divide' && num2 === 0) {
                joke = "DIVIDE BY ZERO?! You just created a black hole! 🌌";
                playLaugh(5);
                result = '♾️ INFINITY';
                resultInput.value = result;
                document.getElementById('currentJoke').textContent = joke;
                addToHistory(joke);
                return;
            }

            if (operation === 'sqrt' && num1 < 0) {
                joke = "NEGATIVE SQUARE ROOT?! IMAGINARY NUMBERS! 👻";
                playLaugh(5);
                result = '🤔 IMAGINARY';
                resultInput.value = result;
                document.getElementById('currentJoke').textContent = joke;
                addToHistory(joke);
                return;
            }

            // Perform calculation
            switch(operation) {
                case 'add':
                    result = num1 + num2;
                    joke = operationJokes.add[Math.floor(Math.random() * operationJokes.add.length)];
                    break;
                case 'subtract':
                    result = num1 - num2;
                    joke = operationJokes.subtract[Math.floor(Math.random() * operationJokes.subtract.length)];
                    break;
                case 'multiply':
                    result = num1 * num2;
                    joke = operationJokes.multiply[Math.floor(Math.random() * operationJokes.multiply.length)];
                    break;
                case 'divide':
                    result = num1 / num2;
                    joke = operationJokes.divide[Math.floor(Math.random() * operationJokes.divide.length)];
                    break;
                case 'power':
                    result = Math.pow(num1, num2);
                    joke = operationJokes.power[Math.floor(Math.random() * operationJokes.power.length)];
                    break;
                case 'sqrt':
                    result = Math.sqrt(num1);
                    joke = operationJokes.sqrt[Math.floor(Math.random() * operationJokes.sqrt.length)];
                    break;
            }

            // Add mockery based on result
            if (result > 1000) {
                joke += " WOW! BIG NUMBER! 🚀";
                playLaugh(4);
            } else if (result < 0) {
                joke += " NEGATIVE! Like your attitude! 😈";
                playLaugh(3);
            } else if (Number.isInteger(result)) {
                joke += " A whole number! How neat! ✨";
                playLaugh(2);
            } else {
                joke += " Decimals? How precise! 📐";
                playLaugh(2);
            }

            // Format result
            resultInput.value = Number.isInteger(result) ? result : result.toFixed(2);
            document.getElementById('currentJoke').textContent = joke;
            addToHistory(joke);
            
            // Shake calculator on big results
            if (result > 10000) {
                document.getElementById('calculator').style.animation = 'shake 0.5s';
                setTimeout(() => {
                    document.getElementById('calculator').style.animation = 'bounceIn 1s ease';
                }, 500);
            }
        }

        function clearAll() {
            document.getElementById('num1').value = '0';
            document.getElementById('num2').value = '0';
            document.getElementById('result').value = '0';
            document.getElementById('currentJoke').textContent = 'Cleared! Like your brain! 🧹';
            playLaugh(1);
        }

        // Keyboard support
        document.addEventListener('keydown', (e) => {
            if (e.key === '+' || e.key === '=') calculate('add');
            if (e.key === '-') calculate('subtract');
            if (e.key === '*') calculate('multiply');
            if (e.key === '/') calculate('divide');
            if (e.key === '^') calculate('power');
            if (e.key === 'r' || e.key === 'R') calculate('sqrt');
            if (e.key === 'c' || e.key === 'C') clearAll();
            if (e.key === 'i' || e.key === 'I') randomInsult();
        });

        // Welcome message
        window.onload = () => {
            setTimeout(() => {
                document.getElementById('currentJoke').textContent = "Welcome, human! Prepare to be mocked! 😈";
                playLaugh(2);
            }, 1000);
        };

        // Save to localStorage
        function saveHistory() {
            localStorage.setItem('insultHistory', JSON.stringify(insultHistory));
        }

        // Load from localStorage
        function loadHistory() {
            const saved = localStorage.getItem('insultHistory');
            if (saved) {
                insultHistory = JSON.parse(saved);
                const historyContainer = document.getElementById('historyContainer');
                historyContainer.innerHTML = insultHistory.map(insult => 
                    `<div class="history-item">${insult}</div>`
                ).join('');
            }
        }

        // Load history on startup
        loadHistory();
    </script>
</body>
</html>
